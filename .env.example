# POLLINATIONS_API_KEY: Diperlukan untuk mengakses Pollinations AI (Text: OpenAI model).
# Anda bisa mendapatkannya secara gratis di enter.pollinations.ai
# Jika menggunakan sistem lama, Anda masih bisa menggunakan GEMINI_API_KEY
POLLINATIONS_API_KEY="pk_..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
